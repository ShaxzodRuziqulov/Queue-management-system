  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:9092" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "00000000-0000-0000-0000-000000000001" },
    { "key": "identityId", "value": "00000000-0000-0000-0000-000000000002" },
    { "key": "businessId", "value": "00000000-0000-0000-0000-000000000003" },
    { "key": "hoursId", "value": "00000000-0000-0000-0000-000000000004" },
    { "key": "serviceId", "value": "00000000-0000-0000-0000-000000000005" },
    { "key": "staffId", "value": "00000000-0000-0000-0000-000000000006" },

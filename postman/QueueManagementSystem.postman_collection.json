  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) { pm.collectionVariables.set('token', j.accessToken); }",
                  "  if (j.userId) { pm.collectionVariables.set('userId', j.userId); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"admin\",\n  \"password\": \"admin\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) { pm.collectionVariables.set('token', j.accessToken); }",
                  "  if (j.userId) { pm.collectionVariables.set('userId', j.userId); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"newuser\",\n  \"password\": \"password12\",\n  \"displayName\": \"Yangi foydalanuvchi\",\n  \"email\": \"new@example.com\",\n  \"phone\": \"+998901112233\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        }
      ]
    },

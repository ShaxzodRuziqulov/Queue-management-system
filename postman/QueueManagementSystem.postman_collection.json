              "mode": "raw",
              "raw": "{\n  \"login\": \"testuser\",\n  \"password\": \"password12\",\n  \"displayName\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"phone\": \"+998901112233\",\n  \"avatarUrl\": null,\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/users"
          }
        },
        {
          "name": "Update user",

              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/v1/businesses/{{businessId}}/review",
            "description": "Faqat PENDING_REVIEW statusidagi biznesni tasdiqlash.\nTasdiqlangandan so'ng status → ACTIVE, reviewedBy/reviewedAt saqlanadi.\nsubscriptionEndDate ixtiyoriy (null = cheksiz)."
          }
        },
        {
          "name": "Review business – REJECT (Admin only)",
          "event": [
            {
              "listen": "test",

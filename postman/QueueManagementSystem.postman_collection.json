            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Updated User\",\n  \"email\": \"updated@example.com\",\n  \"phone\": \"+998909876543\",\n  \"avatarUrl\": null,\n  \"active\": true,\n  \"roles\": [\"ROLE_BUSINESS_OWNER\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/v1/users/{{userId}}",
            "description": "Faqat admin o'zgartirishlar uchun.\nroles massivida ruxsat etilgan qiymatlar: ROLE_USER, ROLE_BUSINESS_OWNER, ROLE_ADMIN\nactive: false → foydalanuvchi bloklandi (login qila olmaydi)"
          }
        },
        {
          "name": "Activate user (Admin only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
